prefix=/ucrt64
includedir=${prefix}/include
libdir=${prefix}/lib

Name: harfbuzz-raster
Description: HarfBuzz CPU rasterizer
Version: 13.2.1
Requires: harfbuzz =  13.2.1
Requires.private: freetype2 >=  12.0.6, glib-2.0 >=  2.30.0, graphite2 >=  1.2.0, libpng, zlib
Libs: -L${libdir} -lharfbuzz-raster
Libs.private: -lm -L${libdir} -lharfbuzz -lusp10 -lgdi32 -lrpcrt4 -luser32 -ldwrite
Cflags: -I${includedir}/harfbuzz
