prefix=/ucrt64
includedir=${prefix}/include
libdir=${prefix}/lib

Name: harfbuzz-vector
Description: HarfBuzz vector converter
Version: 13.2.1
Requires: harfbuzz =  13.2.1
Requires.private: freetype2 >=  12.0.6, glib-2.0 >=  2.30.0, graphite2 >=  1.2.0, zlib
Libs: -L${libdir} -lharfbuzz-vector
Libs.private: -lm -L${libdir} -lharfbuzz -lusp10 -lgdi32 -lrpcrt4 -luser32 -ldwrite
Cflags: -I${includedir}/harfbuzz
