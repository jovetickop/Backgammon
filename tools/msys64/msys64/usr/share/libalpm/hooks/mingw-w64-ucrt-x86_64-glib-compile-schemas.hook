[Trigger]
Type = Path
Operation = Install
Operation = Upgrade
Operation = Remove
Target = ucrt64/share/glib-2.0/schemas/*.gschema.xml
Target = ucrt64/share/glib-2.0/schemas/*.gschema.override

[Action]
Description = Compiling GSettings XML schema files...
When = PostTransaction
Exec = /ucrt64/bin/glib-compile-schemas.exe /ucrt64/share/glib-2.0/schemas
