{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "编译项目",
            "type": "shell",
            "command": "c:/code/Backgammon/build.bat",
            "args": ["-config", "Release"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "运行测试",
            "type": "shell",
            "command": "c:/code/Backgammon/build/TestUnit.exe",
            "group": "test"
        }
    ]
}